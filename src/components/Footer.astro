---
import SquareGridIcon from "./SquareGridIcon.astro";
import GithubIcon from "../assets/icons/social/Github.svg";
import LinkedinIcon from "../assets/icons/social/Linkedin.svg";
import YoutubeIcon from "../assets/icons/social/Youtube.svg";
import {
  GITHUB_CODECARBON_URL,
  LINKEDIN_URL,
  YOUTUBE_URL
} from "../consts";
---

<div class="flex gap-2">
  <SquareGridIcon class="size-6" length="200" />
</div>
<div class="flex items-center justify-center gap-3 mx-4 pt-8">
  <a
    href={GITHUB_CODECARBON_URL}
    target="_blank"
    rel="noopener"
    aria-label="GitHub"
  >
    <GithubIcon class="size-10" />
  </a>
  <a
    href={LINKEDIN_URL}
    target="_blank"
    rel="noopener"
    aria-label="LinkedIn"
  >
    <LinkedinIcon class="size-10" />
  </a>
  <a
    href={YOUTUBE_URL}
    target="_blank"
    rel="noopener"
    aria-label="YouTube"
  >
    <YoutubeIcon class="size-10" />
  </a>
</div>
<div class="mx-auto flex items-center p-4 justify-center gap-2">
  <p class="text-sm min-w-[340px]">
    &copy; 2025 Codecarbon. All rights reserved.
  </p>
</div>
